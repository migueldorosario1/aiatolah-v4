---
// NavMenu.astro — Aiatolah navigation (English/Portuguese)
const pathname = Astro.url.pathname;
const isPt = pathname.startsWith('/pt');

const homeLink = isPt ? "/pt" : "/";
const rankingsLink = isPt ? "/pt/rankings" : "/rankings";
const newsLink = isPt ? "/pt/news" : "/news";
const aboutLink = isPt ? "/pt/about" : "/about";

const tChina = isPt ? "Chineses" : "Chinese";
const tAmerican = isPt ? "Americanos" : "American";
const tOthers = isPt ? "Outros" : "Others";
const tImage = isPt ? "Imagem" : "Image";
const tRankings = isPt ? "Benchmarks" : "Rankings";
const tNews = isPt ? "Notícias" : "News";
const tAbout = isPt ? "Sobre" : "About";
const tArticles = isPt ? "Artigos" : "Articles";
const tVideos = isPt ? "Vídeos & Entrevistas" : "Videos & Interviews";
---

<nav class="aiatolah-nav">
  <div class="nav-inner">

    <a href={homeLink} class="nav-logo">
      <svg class="logo-crescent" width="22" height="22" viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <mask id="crescent-mask">
            <circle cx="11" cy="11" r="9" fill="white"/>
            <circle cx="15.2" cy="10" r="7.2" fill="black"/>
          </mask>
        </defs>
        <circle cx="11" cy="11" r="9" fill="#e8b84b" mask="url(#crescent-mask)"/>
      </svg>
      <span class="logo-ai">AI</span>atolah
    </a>

    <div class="nav-links">

      <!-- Text LLMs -->
      <div class="nav-item dropdown">
        <button class="dropbtn">LLMs <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="dropdown-content">
          <div class="dropdown-section">
            <span class="section-title">🇨🇳 {tChina}</span>
            <a href="https://platform.deepseek.com/" target="_blank" rel="noopener">DeepSeek</a>
            <a href="https://chat.qwen.ai/" target="_blank" rel="noopener">Qwen (Alibaba)</a>
            <a href="https://platform.moonshot.cn/" target="_blank" rel="noopener">Kimi (Moonshot)</a>
            <a href="https://open.bigmodel.cn/" target="_blank" rel="noopener">Zhipu GLM</a>
            <a href="https://cloud.baidu.com/product/wenxinworkshop" target="_blank" rel="noopener">Baidu Ernie</a>
          </div>
          <div class="dropdown-section">
            <span class="section-title">🇺🇸 {tAmerican}</span>
            <a href="https://chat.openai.com/" target="_blank" rel="noopener">ChatGPT (OpenAI)</a>
            <a href="https://claude.ai/" target="_blank" rel="noopener">Claude (Anthropic)</a>
            <a href="https://x.ai/grok" target="_blank" rel="noopener">Grok (xAI)</a>
            <a href="https://gemini.google.com/" target="_blank" rel="noopener">Gemini (Google)</a>
            <a href="https://llama.meta.com/" target="_blank" rel="noopener">Llama (Meta)</a>
          </div>
          <div class="dropdown-section">
            <span class="section-title">🌍 {tOthers}</span>
            <a href="https://mistral.ai/" target="_blank" rel="noopener">Mistral (France)</a>
            <a href="https://cohere.com/" target="_blank" rel="noopener">Cohere (Canada)</a>
            <a href="https://ai.yandex.com/" target="_blank" rel="noopener">YandexGPT (Russia)</a>
          </div>
        </div>
      </div>

      <!-- Image Generators -->
      <div class="nav-item dropdown">
        <button class="dropbtn">{tImage} <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="dropdown-content">
          <div class="dropdown-section">
            <span class="section-title">🇨🇳 {tChina}</span>
            <a href="https://wanx.aliyun.com/" target="_blank" rel="noopener">Wan 2.6 (Alibaba)</a>
            <a href="https://open.bigmodel.cn/dev/api/image-model/cogview" target="_blank" rel="noopener">CogView (Zhipu)</a>
            <a href="https://tongyi.aliyun.com/" target="_blank" rel="noopener">Tongyi Wanxiang</a>
          </div>
          <div class="dropdown-section">
            <span class="section-title">🇺🇸 {tAmerican}</span>
            <a href="https://openai.com/dall-e-3" target="_blank" rel="noopener">DALL-E 3 (OpenAI)</a>
            <a href="https://www.midjourney.com/" target="_blank" rel="noopener">Midjourney</a>
            <a href="https://flux1.ai/" target="_blank" rel="noopener">Flux (Black Forest)</a>
            <a href="https://ideogram.ai/" target="_blank" rel="noopener">Ideogram</a>
          </div>
        </div>
      </div>

      <!-- Rankings -->
      <div class="nav-item">
        <a href={rankingsLink} class="direct-link">{tRankings}</a>
      </div>

      <!-- News Dropdown -->
      <div class="nav-item dropdown">
        <button class="dropbtn">{tNews} <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="dropdown-content news-dropdown-content">
          <div class="dropdown-section">
            <span class="section-title">{isPt ? "Explorar" : "Explore"}</span>
            <a href={newsLink}>{tArticles}</a>
            <a href={isPt ? "/pt/videos" : "/videos"}>{tVideos}</a>
          </div>
        </div>
      </div>

      <!-- About -->
      <div class="nav-item">
        <a href={aboutLink} class="direct-link">{tAbout}</a>
      </div>

    </div>

    <!-- Language flags -->
    <div class="lang-flags">
      <a href="/" class={`flag-btn ${!isPt ? 'active-flag' : ''}`} title="English">🇺🇸</a>
      <a href="/pt" class={`flag-btn ${isPt ? 'active-flag' : ''}`} title="Português">🇧🇷</a>
    </div>

    <!-- Mobile menu toggle button -->
    <button class="mobile-toggle" aria-label="Toggle Menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</nav>

<style>
  .aiatolah-nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(8, 8, 20, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 60px;
  }

  .nav-logo {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    letter-spacing: -0.5px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .logo-crescent {
    flex-shrink: 0;
    filter: drop-shadow(0 0 6px rgba(232, 184, 75, 0.4));
    transition: filter 0.2s;
  }

  .nav-logo:hover .logo-crescent {
    filter: drop-shadow(0 0 10px rgba(232, 184, 75, 0.7));
  }

  .logo-ai {
    color: #00d4ff;
    font-weight: 900;
    letter-spacing: 0.02em;
    margin-right: 1px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
  }

  .lang-flags {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
    align-items: center;
  }

  .flag-btn {
    font-size: 1.5rem;
    text-decoration: none;
    line-height: 1;
    opacity: 0.75;
    transition: opacity 0.2s, transform 0.2s;
  }

  .flag-btn:hover {
    opacity: 1;
    transform: scale(1.15);
  }

  /* Dropdown */
  .nav-item {
    position: relative;
  }

  .dropbtn {
    font-family: 'Outfit', sans-serif;
    background: none;
    border: none;
    color: rgba(255,255,255,0.75);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .dropbtn:hover {
    color: #00d4ff;
  }

  .direct-link {
    font-family: 'Outfit', sans-serif;
    color: rgba(255,255,255,0.75);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.5rem 0;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .direct-link:hover {
    color: #00d4ff;
  }

  .dropdown-content {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    transform: translateY(8px);
    background: rgba(12, 12, 28, 0.98);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    padding: 1rem;
    min-width: 480px;
    max-width: min(520px, calc(100vw - 2rem));
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem 1.5rem;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 769px) {
    .news-dropdown-content {
      min-width: 200px !important;
      max-width: 240px !important;
      grid-template-columns: 1fr !important;
    }
  }

  @media (min-width: 769px) {
    .dropdown:hover .dropdown-content {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
    }
  }

  .dropdown-section {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin-bottom: 0.3rem;
  }

  .dropdown-content a {
    font-family: 'Outfit', sans-serif;
    display: block;
    padding: 0.45rem 0.6rem;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.88rem;
    font-weight: 500;
    transition: all 0.15s;
  }

  .dropdown-content a:hover {
    background: rgba(0, 212, 255, 0.1);
    color: #00d4ff;
    padding-left: 0.9rem;
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    transition: background-color 0.2s, color 0.2s;
    align-items: center;
  }

  .mobile-toggle:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #00d4ff;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: currentColor;
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .mobile-toggle.is-active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .mobile-toggle.is-active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle.is-active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-inner {
      padding: 0 1rem;
      gap: 1rem;
      position: relative;
    }

    .lang-flags {
      margin-left: auto;
    }

    .mobile-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: rgba(8, 8, 20, 0.98);
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem;
      gap: 0.5rem;
      border-top: 1px solid rgba(255,255,255,0.07);
    }

    .nav-links.is-open {
      display: flex;
    }

    .dropdown-content {
      position: static;
      visibility: visible;
      opacity: 1;
      transform: none;
      min-width: 100%;
      grid-template-columns: 1fr;
      box-shadow: none;
      border: none;
      border-left: 2px solid rgba(0,212,255,0.3);
      border-radius: 0;
      padding: 0.5rem 0 0.5rem 1rem;
      background: transparent;
      display: none;
    }

    .dropdown.is-open .dropdown-content {
      display: grid;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const mobileToggle = document.querySelector('.mobile-toggle');
  const navLinks = document.querySelector('.nav-links');

  if (mobileToggle && navLinks) {
    mobileToggle.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('is-open');
      mobileToggle.classList.toggle('is-active');
      mobileToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  }

  // Mobile dropdown toggle
  if (window.innerWidth <= 768) {
    document.querySelectorAll('.dropbtn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const dropdown = btn.closest('.dropdown');
        dropdown?.classList.toggle('is-open');
      });
    });
  }
</script>
