---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const { title, date, category, lang, source, heroImage } = frontmatter;

const isPt = lang === 'pt-br';
const backText = isPt ? '← Voltar para Notícias' : '← Back to News';
const backLink = isPt ? '/pt/news' : '/news';
const publishedText = isPt ? 'Publicado em' : 'Published on';
const sourceText = isPt ? 'Fonte original' : 'Original source';

const formattedDate = new Date(date).toLocaleDateString(isPt ? 'pt-BR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Dynamic Interlinking (Cesta Premium Part 1)
const postModules = isPt 
  ? import.meta.glob('../pages/pt/posts/*.md', { eager: true }) 
  : import.meta.glob('../pages/en/posts/*.md', { eager: true });

const allPosts = Object.entries(postModules).map(([path, mod]: [string, any]) => {
  const fm = mod.frontmatter ?? {};
  const slug = path.split('/').pop().replace('.md', '');
  return {
    title: fm.title ?? slug,
    date: fm.date ?? '2026-01-01',
    url: isPt ? `/pt/posts/${slug}` : `/en/posts/${slug}`,
    category: fm.category ?? 'AI'
  };
});

const relatedPosts = allPosts
  .filter(p => p.title !== title) // exclude current
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()) // sort by date
  .slice(0, 2); // get top 2 latest posts
---

<Layout title={title} description={`${title} - Editorial analysis from a Global South perspective.`} image={heroImage}>
  <main class="post-container">
    <article class="post-article glass-panel animate-fade-in">
      <header class="post-header">
        <a href={backLink} class="back-link">{backText}</a>
        
        <div class="post-meta-top">
          <span class="category-tag">{category}</span>
          <span class="post-date">{publishedText} {formattedDate}</span>
        </div>
        
        <h1 class="post-title gradient-text">{title}</h1>
        
        {source && (
          <a href={source} target="_blank" rel="noopener noreferrer" class="source-link">
            {sourceText} ↗
          </a>
        )}
      </header>
      
      {heroImage && (
        <div class="post-hero-wrapper">
          <img src={heroImage} alt={title} class="post-hero-image" width="860" height="484" />
        </div>
      )}
      
      <div class="post-content">
        <slot />
      </div>
      
      <!-- Cesta Premium: Interlinks -->
      <div class="cesta-premium-container">
        {relatedPosts.length > 0 && (
          <div class="related-articles-section">
            <h3 class="cesta-title">{isPt ? '⚡ Leia Também' : '⚡ Read Also'}</h3>
            <ul class="related-list">
              {relatedPosts.map(post => (
                <li>
                  <a href={post.url} class="related-link">{post.title}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
      
      <footer class="post-footer">
        <div class="footer-logo">
          <svg class="logo-crescent" width="32" height="32" viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <mask id="crescent-mask-post">
                <circle cx="11" cy="11" r="9" fill="white"/>
                <circle cx="15.2" cy="10" r="7.2" fill="black"/>
              </mask>
            </defs>
            <circle cx="11" cy="11" r="9" fill="#e8b84b" mask="url(#crescent-mask-post)"/>
          </svg>
          <span class="logo-text"><span class="logo-ai">AI</span>atolah</span>
        </div>
        <p class="footer-tagline">
          {isPt ? 'Perspectiva independente e multilateral sobre IA e tecnologia.' : 'Independent, multilateral intelligence on AI and technology.'}
        </p>
      </footer>
    </article>
  </main>
</Layout>

<style is:global>
  /* Local styling specifically for post articles */
  .post-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .post-hero-wrapper {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    aspect-ratio: 16 / 9;
  }

  .post-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-hero-wrapper:hover .post-hero-image {
    transform: scale(1.03);
  }

  .post-article {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.6);
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 2rem;
  }

  .back-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #00ff88;
    text-decoration: none;
    transition: transform 0.2s;
    align-self: flex-start;
  }

  .back-link:hover {
    transform: translateX(-4px);
  }

  .post-meta-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .category-tag {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(0, 212, 255, 0.12);
    color: #00d4ff;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-family: 'Inter', sans-serif;
  }

  .post-date {
    font-size: 0.82rem;
    color: #888899;
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -1px;
    margin: 0.5rem 0;
  }

  .source-link {
    font-size: 0.82rem;
    color: #888899;
    text-decoration: none;
    align-self: flex-start;
    transition: color 0.2s;
  }

  .source-link:hover {
    color: #fff;
  }

  /* Markdown content styles styling inside global layout */
  .post-content {
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.1rem;
    line-height: 1.8;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-content h1 {
    display: none; /* Hide the duplicate main title inside markdown */
  }

  .post-content h2 {
    font-size: 1.5rem;
    color: #fff;
    margin-top: 1.5rem;
    border-left: 3px solid #00ff88;
    padding-left: 0.75rem;
  }

  .post-content p {
    margin-bottom: 0.5rem;
  }

  .post-content ul, .post-content ol {
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-content blockquote {
    border-left: 4px solid rgba(0, 255, 136, 0.2);
    background: rgba(255, 255, 255, 0.02);
    padding: 1rem 1.5rem;
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #888899;
  }

  /* Micro-charts container table inside posts */
  .aiatolah-benchmark-card table {
    width: 100%;
    margin: 15px 0;
  }

  .aiatolah-benchmark-card table th, .aiatolah-benchmark-card table td {
    padding: 8px 12px;
  }

  /* Post Footer */
  .post-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-text {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: #fff;
  }

  .logo-ai {
    color: #00d4ff;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: #888899;
  }

  /* Touch and Mobile responsive refinements */
  @media (max-width: 768px) {
    .post-container {
      padding: 1.5rem 1rem;
    }
    .post-article {
      padding: 1.75rem 1.25rem;
      gap: 1.5rem;
    }
    .post-title {
      font-size: 1.85rem;
    }
    .post-content {
      font-size: 1rem;
      line-height: 1.7;
    }
    .aiatolah-benchmark-card {
      padding: 12px !important;
      margin: 15px 0 !important;
    }
    .aiatolah-benchmark-card table {
      font-size: 11px !important;
    }
    .aiatolah-benchmark-card th, .aiatolah-benchmark-card td {
      padding: 6px 4px !important;
    }
  }

  /* Cesta Premium Styling */
  .cesta-premium-container {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .related-articles-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cesta-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #00ff88;
    margin: 0;
  }

  .related-list {
    list-style: none !important;
    padding-left: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.2s, padding-left 0.2s;
    display: inline-block;
  }

  .related-link:hover {
    color: #00d4ff;
    padding-left: 4px;
  }
</style>
